{
    "name": "bigcalm/laracollab-teamwork-import",
    "description": "Import data from Teamwork.com API v3 into LaraCollab",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "spatie/laravel-permission": "^6.9"
    },
    "audit": {
        "ignore": [
            "PKSA-mdq4-51ck-6kdq",
            "PKSA-8qx3-n5y5-vvnd",
            "PKSA-q46n-4fdk-zjr4",
            "PKSA-qzrn-rnz3-85w1",
            "PKSA-w7xr-vk7n-rstm"
        ]
    },
    "autoload": {
        "psr-4": {
            "LaraCollab\\TeamworkImport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraCollab\\TeamworkImport\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraCollab\\TeamworkImport\\TeamworkImportServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "audit": {
            "block-insecure": false
        }
    }
}
